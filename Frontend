import { useCallback, useEffect, useRef, useState } from "react";
import { Link } from "react-router-dom";
import axios from "ajax";

const BACKEND_URL = process.env.REACT_APP_BACKEND_URL;
const API = `${BACKEND_URL}/api`;

const MEDIAPIPE_HANDS = "https://cdn.jsdelivr.net/npm/@mediapipe/hands@0.4.1675469240/hands.js";
const MEDIAPIPE_DRAW  = "https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils@0.3.1675466124/drawing_utils.js";
const MEDIAPIPE_CAM   = "https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils@0.3.1675466862/camera_utils.js";

const ALL_LABELS = [
    "HELLO", "I LOVE YOU", "GOOD", "OK", "PEACE", "CALL ME",
    "STOP", "ROCK ON", "POINT", "THREE", "FIST", "L", "C", "O", "W / SIX",
];

// load external script once
const loadScript = (src) => new Promise((resolve, reject) => {
    if (document.querySelector(`script[src="${src}"]`)) return resolve();
    const s = document.createElement("script");
    s.src = src;
    s.crossOrigin = "anonymous";
    s.onload  = () => resolve();
    s.onerror = () => reject(new Error(`Failed to load ${src}`));
    document.head.appendChild(s);
});

export default function SignLanguageRecognizer() {
    const videoRef        = useRef(null);
    const canvasRef       = useRef(null);
    const handsRef        = useRef(null);
    const cameraRef       = useRef(null);
    const lastSentRef     = useRef(0);
    const lastLabelRef    = useRef("");
    const stableCountRef  = useRef(0);

    const [running,   setRunning]   = useState(false);
    const [loading,   setLoading]   = useState(false);
    const [label,     setLabel]     = useState("—");
    const [meaning,   setMeaning]   = useState("Start the camera and show a sign");
    const [confidence,setConfidence]= useState(0);
    const [history,   setHistory]   = useState([]);
    const [error,     setError]     = useState("");
    const [bump,      setBump]      = useState(false);

    // initialize MediaPipe once
    const initHands = useCallback(async () => {
        await Promise.all([
            loadScript(MEDIAPIPE_HANDS),
            loadScript(MEDIAPIPE_DRAW),
            loadScript(MEDIAPIPE_CAM),
        ]);
        // eslint-disable-next-line no-undef
        const hands = new Hands({
            locateFile: (file) =>
                `https://cdn.jsdelivr.net/npm/@mediapipe/hands@0.4.1675469240/${file}`,
        });
        hands.setOptions({
            maxNumHands: 1,
            modelComplexity: 1,
            minDetectionConfidence: 0.6,
            minTrackingConfidence:  0.5,
        });
        hands.onResults(onResults);
        handsRef.current = hands;
    }, []);

    const sendRecognize = useCallback(async (landmarks, handedness) => {
        const now = performance.now();
        if (now - lastSentRef.current < 250) return; // throttle ~4 fps
        lastSentRef.current = now;
        try {
            const { data } = await axios.post(`${API}/recognize`, {
                landmarks: landmarks.map((p) => ({ x: p.x, y: p.y, z: p.z ?? 0 })),
                handedness,
            });
            setLabel(data.label);
            setMeaning(data.meaning);
            setConfidence(data.confidence);

            // History: add when label stable for ~3 frames
            if (data.label !== "UNKNOWN") {
                if (data.label === lastLabelRef.current) {
                    stableCountRef.current += 1;
                } else {
                    stableCountRef.current = 1;
                    lastLabelRef.current   = data.label;
                }
                if (stableCountRef.current === 3) {
                    setHistory((h) => [...h, data.label].slice(-12));
                    setBump(true);
                    setTimeout(() => setBump(false), 250);
                }
            }
        } catch (e) {
            console.warn("recognize failed", e?.message);
        }
    }, []);

    const onResults = useCallback((results) => {
        const canvas = canvasRef.current;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        const w = canvas.width  = canvas.offsetWidth;
        const h = canvas.height = canvas.offsetHeight;
        ctx.clearRect(0, 0, w, h);

        if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
            const landmarks  = results.multiHandLandmarks[0];
            const handedness = results.multiHandedness?.[0]?.label ?? "Right";
            // eslint-disable-next-line no-undef
            drawConnectors(ctx, landmarks, HAND_CONNECTIONS, { color: "#22d3ee", lineWidth: 3 });
            // eslint-disable-next-line no-undef
            drawLandmarks (ctx, landmarks,                    { color: "#34d399", lineWidth: 1, radius: 4 });
            sendRecognize(landmarks, handedness);
        } else {
            setLabel("—");
            setMeaning("Show your hand to the camera");
            setConfidence(0);
            lastLabelRef.current   = "";
            stableCountRef.current = 0;
        }
    }, [sendRecognize]);

    const start = useCallback(async () => {
        setError(""); setLoading(true);
        try {
            if (!handsRef.current) await initHands();
            // eslint-disable-next-line no-undef
            const camera = new Camera(videoRef.current, {
                onFrame: async () => {
                    if (handsRef.current && videoRef.current) {
                        await handsRef.current.send({ image: videoRef.current });
                    }
                },
                width: 640, height: 480,
            });
            cameraRef.current = camera;
            await camera.start();
            setRunning(true);
        } catch (e) {
            setError(
                e?.message?.includes("Permission") || e?.name === "NotAllowedError"
                    ? "Camera permission denied. Please allow camera access in your browser."
                    : `Failed to start camera: ${e?.message ?? e}`
            );
        } finally { setLoading(false); }
    }, [initHands]);

    const stop = useCallback(() => {
        try { cameraRef.current?.stop?.(); } catch (_) {}
        const stream = videoRef.current?.srcObject;
        if (stream) stream.getTracks().forEach((t) => t.stop());
        if (videoRef.current) videoRef.current.srcObject = null;
        setRunning(false);
        setLabel("—"); setMeaning("Camera stopped"); setConfidence(0);
    }, []);

    useEffect(() => () => stop(), [stop]);

    const clearHistory = () => setHistory([]);

    return (
        <div className="sl-app" data-testid="sl-app">
            <header className="sl-header">
                <div className="sl-brand">
                    <div className="sl-logo" aria-hidden>
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" strokeWidth="2.2"
                             strokeLinecap="round" strokeLinejoin="round">
                            <path d="M9 11V6a2 2 0 1 1 4 0v5" />
                            <path d="M13 11V4a2 2 0 1 1 4 0v9" />
                            <path d="M17 13V7a2 2 0 1 1 4 0v8a7 7 0 0 1-7 7H9a4 4 0 0 1-4-4l-2-6a2 2 0 0 1 4-1l1 3" />
                        </svg>
                    </div>
                    <div>
                        <h1 className="sl-title">Sign Language Recognition</h1>
                        <p className="sl-subtitle">Real-time gesture detection</p>
                    </div>
                </div>
                <div className="sl-header-right">
                    <span className="sl-status" data-state={running ? "on" : "off"}
                          data-testid="status-pill">
                        <span className="sl-dot" /> {running ? "Live" : "Idle"}
                    </span>
                    <Link to="/guide" className="sl-guide-link" data-testid="guide-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" strokeWidth="2"
                             strokeLinecap="round" strokeLinejoin="round">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                        </svg>
                        Gesture Guide
                    </Link>
                </div>
            </header>

            <div className="sl-grid">
                <section className="sl-card" data-testid="camera-card">
                    <p className="sl-card-title">Camera Stage</p>
                    <div className="sl-stage">
                        <video ref={videoRef} playsInline muted />
                        <canvas ref={canvasRef} />
                        {!running && (
                            <div className="sl-stage-overlay">
                                <div>
                                    <h3>{loading ? "Loading model…" : "Camera is off"}</h3>
                                    <p>{loading ? "Setting up MediaPipe Hands"
                                                : "Click Start to begin recognizing signs from your webcam."}</p>
                                </div>
                            </div>
                        )}
                    </div>
                    <div className="sl-controls">
                        {!running ? (
                            <button className="sl-btn" data-variant="primary" onClick={start}
                                    disabled={loading} data-testid="start-btn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                    <polygon points="6,4 20,12 6,20" />
                                </svg>
                                {loading ? "Loading…" : "Start Camera"}
                            </button>
                        ) : (
                            <button className="sl-btn" data-variant="danger" onClick={stop}
                                    data-testid="stop-btn">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                                    <rect x="6" y="6" width="12" height="12" rx="2" />
                                </svg>
                                Stop Camera
                            </button>
                        )}
                        <button className="sl-btn" data-variant="ghost" onClick={clearHistory}
                                data-testid="clear-history-btn">
                            Clear History
                        </button>
                    </div>
                    {error && <div className="sl-error" data-testid="error-banner">{error}</div>}
                </section>

                <aside className="sl-card sl-letter-card" data-testid="result-card">
                    <p className="sl-letter-label-top">Detected Sign</p>
                    <div className="sl-letter" data-bump={bump ? "1" : "0"}
                         data-testid="detected-label">{label}</div>
                    <div className="sl-meaning" data-testid="detected-meaning">{meaning}</div>
                    <div className="sl-conf">
                        <div className="sl-conf-fill"
                             style={{ width: `${Math.round(confidence * 100)}%` }} />
                    </div>
                    <div className="sl-conf-meta">
                        <span>CONFIDENCE</span>
                        <span data-testid="confidence-value">
                            {Math.round(confidence * 100)}%
                        </span>
                    </div>

                    <div className="sl-history">
                        <div className="sl-history-title">Recent Signs</div>
                        <div className="sl-history-row" data-testid="history-row">
                            {history.length === 0
                                ? <span className="sl-history-empty">No signs detected yet.</span>
                                : history.map((s, i) => <span key={i} className="sl-chip">{s}</span>)}
                        </div>
                    </div>

                    <div className="sl-legend">
                        {ALL_LABELS.map((l) => (
                            <div key={l} className="sl-legend-item"
                                 data-active={label === l ? "1" : "0"}>
                                {l}
                            </div>
                        ))}
                    </div>
                </aside>
            </div>

            <footer className="sl-foot">
                Tip — keep your hand inside the frame, ~30 cm from the camera,
                with good lighting for best accuracy.
            </footer>
        </div>
    );
}
